# ============================================================
# .env.example — TEMPLATE CẤU HÌNH MÔI TRƯỜNG
# Copy file này thành .env và điền giá trị thật vào
# cp .env.example .env
# ============================================================

# DATABASE
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/website_application?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=your_db_username
SPRING_DATASOURCE_PASSWORD=your_strong_db_password

# JWT
# Tạo key mới: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET_KEY=your_64_char_hex_secret_key_here
JWT_EXPIRATION=86400000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# GOOGLE OAUTH
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# MINIO / BACKBLAZE B2
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET_PRODUCT=products-image
MINIO_BUCKET_CATEGORY=products-image
MINIO_BUCKET_USER=products-image
MINIO_BUCKET_BANNER=products-image
MINIO_EXTERNAL_URL=http://localhost:9000
MINIO_REGION=us-east-1

# VNPAY
VNP_TMN_CODE=your_vnp_tmn_code
VNP_HASH_SECRET=your_vnp_hash_secret
VNP_RETURN_URL=http://localhost:5173/payment-success

# MYSQL ROOT (dùng cho Docker Compose)
MYSQL_ROOT_PASSWORD=your_mysql_root_password

# REDIS (Docker local — không cần đăng ký tài khoản nào)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# KEYCLOAK (Phase 2 — chạy local bằng Docker)
KC_DB_USER=keycloak_user
KC_DB_PASSWORD=your_keycloak_db_password
KC_ADMIN_PASSWORD=your_keycloak_admin_password
