{
  "id": "ecommerce",
  "realm": "ecommerce",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "registrationEmailAsUsername": false,
  "rememberMe": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "Regular customer role"
      },
      {
        "name": "ADMIN",
        "description": "Administrator role"
      },
      {
        "name": "MODERATOR",
        "description": "Moderator role"
      }
    ]
  },
  "defaultRoles": [
    "USER"
  ],
  "clients": [
    {
      "clientId": "ecommerce-backend",
      "name": "Ecommerce Backend Service",
      "description": "Confidential client for BE-Application resource server and FE authentication flow",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "secret": "ecommerce-backend-secret-placeholder",
      "redirectUris": [
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "roles",
        "profile",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "authenticateByDefault": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "PLACEHOLDER_GOOGLE_CLIENT_ID",
        "clientSecret": "PLACEHOLDER_GOOGLE_CLIENT_SECRET",
        "useJwksUrl": "true",
        "syncMode": "FORCE",
        "updateProfileFirstLoginMode": "off"
      }
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@technova.com",
      "firstName": "Quản Trị",
      "lastName": "Hệ Thống",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "ADMIN"
      ]
    },
    {
      "username": "user",
      "email": "user@technova.com",
      "firstName": "Khách",
      "lastName": "Hàng",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "user123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "USER"
      ]
    }
  ]
}
